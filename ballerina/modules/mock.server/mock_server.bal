    # Update an article
    #
    # + articleId - The unique identifier for the article which is given by Intercom
    # + return - returns can be any of following types 
    # http:Ok (successful)
    # http:NotFound (Article Not Found)
    # http:Unauthorized (Unauthorized)
    resource function put articles/[int articleId](@http:Header {name: "Intercom-Version"} IntercomVersion? intercomVersion, @http:Payload UpdateArticleRequest payload) returns Article|ErrorNotFound|ErrorUnauthorized {
        string? payloadParentId = payload.parentId;
        int parentIdValue = 789;
        if payloadParentId is string && payloadParentId != "" {
            int|error parseResult = int:fromString(payloadParentId);
            if parseResult is int {
                parentIdValue = parseResult;
            }
        }
        
        return {
            "type": "article",
            "id": articleId.toString(),
            "workspace_id": "ws_123",
            "title": payload.title ?: "Updated Article",
            "description": payload.description ?: "Updated description",
            "body": payload.body ?: "<p>Updated article content</p>",
            "author_id": payload.authorId ?: 456,
            "state": payload.state ?: "published",
            "created_at": 1640995200,
            "updated_at": 1641168000,
            "url": "https://help.example.com/articles/updated",
            "parent_id": parentIdValue,
            "parent_ids": [parentIdValue],
            "parent_type": payload.parentType ?: "collection"
        };
    }

    # Update a contact
    #
    # + contactId - id
    # + return - returns can be any of following types 
    # http:Ok (successful)
    # http:Unauthorized (Unauthorized)
    resource function put contacts/[string contactId](@http:Header {name: "Intercom-Version"} IntercomVersion? intercomVersion, @http:Payload ContactscontactIdBody payload) returns ContactWithPush|ErrorUnauthorized {
        string? payloadExternalId = payload?.externalId;
        string? payloadRole = payload?.role;
        string? payloadEmail = payload?.email;
        string? payloadPhone = payload?.phone;
        string? payloadName = payload?.name;
        int? payloadSignedUpAt = payload?.signedUpAt;
        int? payloadLastSeenAt = payload?.lastSeenAt;
        int? payloadOwnerId = payload?.ownerId;
        boolean? payloadUnsubscribedFromEmails = payload?.unsubscribedFromEmails;
        record {} payloadCustomAttributes = payload?.customAttributes ?: {};
        
        return {
            "type": "contact",
            "id": contactId,
            "workspace_id": "ws_123",
            "external_id": payloadExternalId ?: "updated_ext_456",
            "role": payloadRole ?: "user",
            "email": payloadEmail ?: "updated@example.com",
            "phone": payloadPhone ?: "+1555987654",
            "name": payloadName ?: "Updated Contact",
            "created_at": 1640995200,
            "updated_at": 1641168000,
            "signed_up_at": payloadSignedUpAt ?: 1640908800,
            "last_seen_at": payloadLastSeenAt ?: 1641168000,
            "owner_id": payloadOwnerId,
            "unsubscribed_from_emails": payloadUnsubscribedFromEmails ?: false,
            "marked_email_as_spam": false,
            "has_hard_bounced": false,
            "custom_attributes": payloadCustomAttributes,
            "email_domain": "example.com"
        };
    }

    # Update a conversation
    #
    # + conversationId - The id of the conversation to target
    # + display_as - Set to plaintext to retrieve conversation messages in plain text
