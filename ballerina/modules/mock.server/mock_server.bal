    # Update a ticket
    #
    # + ticketId - The unique identifier for the ticket which is given by Intercom.
    # {% admonition type="info" name="Not the Inbox ticket ID" %}
    # This is the internal `id` field from the API response, not the `ticket_id` displayed in the Intercom Inbox (e.g., #12345). Use the `id` value from the ticket object returned by the API.
    # {% /admonition %}
    # + return - returns can be any of following types 
    # http:Ok (Successful response)
    # http:NotFound (Assignee not found)
    # http:BadRequest (Ticket state id is not valid or is not associated with the ticket type.)
    # http:Unauthorized (Unauthorized)
    resource function put tickets/[string ticketId](@http:Header {name: "Intercom-Version"} IntercomVersion? intercomVersion, @http:Payload TicketsticketIdBody payload) returns Ticket|JsonNotFound|JsonBadRequest|ErrorUnauthorized {
        int? payloadAdminId = payload?.adminId;
        string payloadAdminIdStr = "admin_456";
        if payloadAdminId is int {
            payloadAdminIdStr = payloadAdminId.toString();
        }
        
        return {
            "type": "ticket",
            "id": ticketId,
            "ticket_id": "TK-UPDATED",
            "category": "Customer",
            "created_at": 1640995200,
            "updated_at": 1641168000,
            "open": payload?.open ?: true,
            "is_shared": payload?.isShared ?: true,
            "admin_assignee_id": payloadAdminIdStr,
            "team_assignee_id": payload?.assigneeId,
            "snoozed_until": payload?.snoozedUntil,
            "ticket_type": {
                "type": "ticket_type",
                "id": "type_updated_123",
                "name": "Updated Ticket Type",
                "description": "Updated ticket type description",
                "icon": "update",
                "category": "Customer",
                "workspace_id": "ws_123",
                "created_at": 1640908800,
                "updated_at": 1641168000,
                "archived": false
            },
            "ticket_state": {
                "type": "ticket_state",
                "id": payload?.ticketStateId ?: "state_updated_123",
                "category": "in_progress",
                "internal_label": "Updated",
                "external_label": "Being Updated"
            },
            "contacts": {
                "type": "contact.list",
                "contacts": [
                    {
                        "type": "contact",
                        "id": "contact_updated_456",
                        "external_id": "ext_updated_456"
                    }
                ]
            },
            "ticket_parts": {
                "type": "ticket_part.list",
                "total_count": 1,
                "ticket_parts": [
                    {
                        "type": "ticket_part",
                        "id": "part_updated_123",
                        "part_type": "note",
                        "body": "Ticket has been updated",
                        "created_at": 1641168000,
                        "updated_at": 1641168000,
                        "author": {
                            "type": "admin",
                            "id": payloadAdminIdStr,
                            "name": "Update Admin",
                            "email": "admin@example.com"
                        }
                    }
                ]
            },
            "ticket_attributes": payload?.ticketAttributes ?: {}
        };
    }
}