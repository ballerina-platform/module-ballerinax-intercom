    resource function put conversations/[int conversationId](@http:Header {name: "Intercom-Version"} IntercomVersion? intercomVersion, @http:Query {name: "display_as"} string? displayAs, @http:Payload UpdateConversationRequest payload) returns Conversation|ErrorNotFound|ErrorUnauthorized|ErrorForbidden {
