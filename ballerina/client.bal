    # + ticketId - ticket_id
    # + tagId - The unique identifier for the tag which is given by Intercom
    # + headers - Headers to be sent with the request 
    # + return - successful 
    resource isolated function delete tickets/[string ticketId]/tags/[string tagId](TagstagIdBody payload, DetachTagFromTicketHeaders headers = {}) returns Tag|error {
        string resourcePath = string `/tickets/${getEncodedUri(ticketId)}/tags/${getEncodedUri(tagId)}`;
        map<string|string[]> httpHeaders = http:getHeaderMap(headers);
        http:Request request = new;
        json jsonBody = jsondata:toJson(payload);
        request.setPayload(jsonBody, "application/json");
        return self.clientEp->delete(resourcePath, request, httpHeaders);
    }

