# Visitors are useful for representing anonymous people that have not yet been identified. They usually represent website visitors. Visitors are not visible in Intercom platform. The Visitors resource provides methods to fetch, update, convert and delete
public type Visitor record {
    # The id of the admin that owns the Visitor
    @jsondata:Name {value: "owner_id"}
    string? ownerId?;
    # The utm_medium of the visitor
    @jsondata:Name {value: "utm_medium"}
    string? utmMedium?;
    # The time the Visitor was added to Intercom
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # Identifies if this visitor has do not track enabled
    @jsondata:Name {value: "do_not_track"}
    boolean? doNotTrack?;
    # Value is 'visitor'
    string 'type = "visitor";
    # The pseudonym of the visitor
    string? pseudonym?;
    # Collection of segments associated with a visitor
    VisitorSegments segments?;
    # The custom attributes you have set on the Visitor
    @jsondata:Name {value: "custom_attributes"}
    record {|string...;|} customAttributes?;
    # List of companies associated with a visitor
    VisitorCompanies companies?;
    # Whether the Visitor is unsubscribed from emails
    @jsondata:Name {value: "unsubscribed_from_emails"}
    boolean unsubscribedFromEmails?;
    # The last time the Visitor was updated
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # Geographic location information for the visitor
    @jsondata:Name {value: "location_data"}
    VisitorLocationData locationData?;
    # The Intercom defined id representing the Visitor
    string id?;
    # The id of the app the visitor is associated with
    @jsondata:Name {value: "app_id"}
    string appId?;
    # The email of the visitor
    string email?;
    # The utm_content of the visitor
    @jsondata:Name {value: "utm_content"}
    string? utmContent?;
    # The time the Visitor signed up for your product
    @jsondata:Name {value: "signed_up_at"}
    int signedUpAt?;
    # Identifies if this visitor has had a hard bounce
    @jsondata:Name {value: "has_hard_bounced"}
    boolean hasHardBounced?;
    # The utm_campaign of the visitor
    @jsondata:Name {value: "utm_campaign"}
    string? utmCampaign?;
    # Avatar image information for a visitor
    VisitorAvatar avatar?;
    # Collection of tags associated with a visitor
    VisitorTags tags?;
    # The utm_term of the visitor
    @jsondata:Name {value: "utm_term"}
    string? utmTerm?;
    # The referer of the visitor
    string? referrer?;
    # Social media profiles associated with the visitor
    @jsondata:Name {value: "social_profiles"}
    VisitorSocialProfiles socialProfiles?;
    # Identifies if this visitor has marked an email as spam
    @jsondata:Name {value: "marked_email_as_spam"}
    boolean markedEmailAsSpam?;
    # Automatically generated identifier for the Visitor
    @jsondata:Name {value: "user_id"}
    string userId?;
    # The phone number of the visitor
    string? phone?;
    # The number of sessions the Visitor has had
    @jsondata:Name {value: "session_count"}
    int sessionCount?;
    # The name of the visitor
    string? name?;
    # Identifies if this visitor is anonymous
    boolean anonymous?;
    # The time the Lead last recorded making a request
    @jsondata:Name {value: "las_request_at"}
    int lasRequestAt?;
    # The time the Visitor was added to Intercom
    @jsondata:Name {value: "remote_created_at"}
    int remoteCreatedAt?;
    # The utm_source of the visitor
    @jsondata:Name {value: "utm_source"}
    string? utmSource?;
};

# The Articles API is a central place to gather all information and take actions on your articles. Articles can live within collections and sections, or alternatively they can stand alone
public type Article ArticleListItem;

# The request payload for updating a ticket type.
# You can copy the `icon` property for your ticket type from [Twemoji Cheatsheet](https://twemoji-cheatsheet.vercel.app/)
public type UpdateTicketTypeRequest record {
    # The archived status of the ticket type
    boolean archived?;
    # Whether the tickets associated with this ticket type are intended for internal use only or will be shared with customers. This is currently a limited attribute
    @jsondata:Name {value: "is_internal"}
    boolean isInternal = false;
    # The name of the ticket type
    string name?;
    # The icon of the ticket type
    string icon = "🎟️";
    # The description of the ticket type
    string description?;
    # Category of the Ticket Type
    "Customer"|"Back-office"|"Tracker" category?;
};

