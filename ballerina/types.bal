    # (UNIX timestamp) The time when the contact was last updated
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # (UNIX timestamp) The time when the contact last messaged in
    @jsondata:Name {value: "last_replied_at"}
    int? lastRepliedAt?;
    # The name of the browser which the contact is using
    string? browser?;
    # The name of the iOS app which the contact is using
    @jsondata:Name {value: "ios_app_name"}
    string? iosAppName?;
    # The unique identifier for the contact which is given by Intercom
    string id?;
    # The version of the browser which the contact is using
    @jsondata:Name {value: "browser_version"}
    string? browserVersion?;
    # The language set by the browser which the contact is using
    @jsondata:Name {value: "browser_language"}
    string? browserLanguage?;
    # The version of the iOS SDK which the contact is using
    @jsondata:Name {value: "ios_sdk_version"}
    string? iosSdkVersion?;
    # The contact's email
    string email?;
    # (UNIX timestamp) The time specified for when a contact signed up
    @jsondata:Name {value: "signed_up_at"}
    int? signedUpAt?;
    # The version of iOS which the contact is using
    @jsondata:Name {value: "ios_os_version"}
    string? iosOsVersion?;
    # Whether the contact has had an email sent to them hard bounce
    @jsondata:Name {value: "has_hard_bounced"}
    boolean hasHardBounced?;
    # The operating system which the contact is using
    string? os?;
    # The version of the iOS app which the contact is using
    @jsondata:Name {value: "ios_app_version"}
    string? iosAppVersion?;
    # (UNIX timestamp) The time when the contact was last messaged
    @jsondata:Name {value: "last_contacted_at"}
    int? lastContactedAt?;
    # The Android device which the contact is using
    @jsondata:Name {value: "android_device"}
    string? androidDevice?;
    # (UNIX timestamp) The last time the contact used the iOS app
    @jsondata:Name {value: "ios_last_seen_at"}
    int? iosLastSeenAt?;
    # The version of the Android app which the contact is using
    @jsondata:Name {value: "android_app_version"}
    string? androidAppVersion?;
    # Avatar image information for a contact
    ContactAvatar? avatar?;
    # An object containing tags meta data about the tags that a contact has. Up to 10 will be displayed here. Use the url to get more
    ContactTags? tags?;
    # Whether the contact has marked an email sent to them as spam
    @jsondata:Name {value: "marked_email_as_spam"}
    boolean markedEmailAsSpam?;
    # Contact's social media profile information and links
