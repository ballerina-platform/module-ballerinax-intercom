    # The start date that you request data for. It must be formatted as a unix timestamp
    @jsondata:Name {value: "created_at_after"}
    int createdAtAfter;
};

# The list of contacts (users or leads) involved in this conversation. This will only contain one customer unless more were added via the group conversation feature
public type ConversationContacts record {
    "contact.list" 'type?;
    # The list of contacts (users or leads) involved in this conversation. This will only contain one customer unless more were added via the group conversation feature
    ContactReference[] contacts?;
};

# The unique identifiers to convert a single Visitor
public type ConvertVisitorRequestVisitor anydata;

# Conversations are how you can communicate with users in Intercom. They are created when a contact replies to an outbound message, or when one admin directly sends a message to a single contact
public type Conversation record {
    # The time the conversation was created
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # If set this is the time in the future when this conversation will be marked as open. i.e. it will be in a snoozed state until this time. i.e. it will be in a snoozed state until this time
    @jsondata:Name {value: "snoozed_until"}
    int? snoozedUntil?;
    # Rating given to the conversation by participants
    @jsondata:Name {value: "conversation_rating"}
    ConversationRating? conversationRating?;
    # The type of the conversation part that started this conversation. Can be Contact, Admin, Campaign, Automated or Operator initiated
    ConversationSource 'source?;
    # Service level agreement settings applied to this conversation
    @jsondata:Name {value: "sla_applied"}
    SlaApplied? slaApplied?;
    # Always conversation
    string 'type?;
    # The title given to the conversation
    string? title?;
    # AI agent configuration and details associated with the conversation
    @jsondata:Name {value: "ai_agent"}
    AiAgent aiAgent?;
    # Custom attributes and metadata assigned to the conversation
    @jsondata:Name {value: "custom_attributes"}
    CustomAttributes customAttributes?;
    # The id of the admin assigned to the conversation. If it's not assigned to an admin it will return null
    @jsondata:Name {value: "admin_assignee_id"}
    int? adminAssigneeId?;
    # The list of teammates who participated in the conversation (wrote at least one conversation part)
    ConversationTeammates? teammates?;
    # The last time the conversation was updated
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # The id of the team assigned to the conversation. If it's not assigned to a team it will return null
    @jsondata:Name {value: "team_assignee_id"}
    string? teamAssigneeId?;
    # Indicates whether the AI Agent participated in the conversation
    @jsondata:Name {value: "ai_agent_participated"}
    boolean aiAgentParticipated?;
    # Companies allow you to represent organizations using your product. Each company will have its own description and be associated with contacts. You can fetch, create, update and list companies
    Company company?;
    # The id representing the conversation
    string id?;
    # Can be set to "open", "closed" or "snoozed"
    "open"|"closed"|"snoozed" state?;
    # Indicates whether a conversation has been read
    boolean read?;
    # Individual messages and parts that make up the conversation thread
    @jsondata:Name {value: "conversation_parts"}
    ConversationParts conversationParts?;
    # The last time a Contact responded to an Admin. In other words, the time a customer started waiting for a response. Set to null if last reply is from an Admin
    @jsondata:Name {value: "waiting_since"}
    int? waitingSince?;
    # If marked as priority, it will return priority or else not_priority
    "priority"|"not_priority" priority?;
    # A list of tags objects associated with a conversation
    Tags tags?;
    # Details about the first reply from a contact in the conversation
    @jsondata:Name {value: "first_contact_reply"}
    ConversationFirstContactReply? firstContactReply?;
    # External objects and resources linked to this conversation
    @jsondata:Name {value: "linked_objects"}
    LinkedObjectList linkedObjects?;
    # Indicates whether a conversation is open (true) or closed (false)
    boolean open?;
    # The list of contacts (users or leads) involved in this conversation. This will only contain one customer unless more were added via the group conversation feature
    ConversationContacts contacts?;
    # A Statistics object containing all information required for reporting, with timestamps and calculated metrics
    ConversationStatistics? statistics?;
};

