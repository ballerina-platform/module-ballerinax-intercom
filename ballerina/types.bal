# A News Item is a content type in Intercom enabling you to announce product updates, company news, promotions, events and more with your customers
public type NewsItem record {
    # URL of the image used as cover. Must have .jpg or .png extension
    @jsondata:Name {value: "cover_image_url"}
    string? coverImageUrl?;
    # When set to true, the news item will appear in the messenger newsfeed without showing a notification badge
    @jsondata:Name {value: "deliver_silently"}
    boolean deliverSilently?;
    # A list of newsfeed_assignments to assign to the specified newsfeed
    @jsondata:Name {value: "newsfeed_assignments"}
    NewsfeedAssignment[] newsfeedAssignments?;
    # Timestamp for when the news item was created
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # The type of object
    "news-item" 'type?;
    # The title of the news item
    string title?;
    # The news item body, which may contain HTML
    string body?;
    # The id of the sender of the news item. Must be a teammate on the workspace
    @jsondata:Name {value: "sender_id"}
    int senderId?;
    # Label names displayed to users to categorize the news item
    string[] labels?;
    # The id of the workspace which the news item belongs to
    @jsondata:Name {value: "workspace_id"}
    string workspaceId?;
    # Timestamp for when the news item was last updated
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # Ordered list of emoji reactions to the news item. When empty, reactions are disabled
    string[] reactions?;
    # The unique identifier for the news item which is given by Intercom
    string id?;
    # News items will not be visible to your users in the assigned newsfeeds until they are set live
    "draft"|"live" state?;
};

# Tickets are how you track requests from your users
public type Ticket record {
    # Current state of the ticket
    @jsondata:Name {value: "ticket_state"}
    TicketState? ticketState?;
    # Type classification of the ticket
    @jsondata:Name {value: "ticket_type"}
    TicketType? ticketType?;
    # Collection of ticket parts containing messages and updates
    @jsondata:Name {value: "ticket_parts"}
    TicketParts ticketParts?;
    # The time the ticket was created as a UTC Unix timestamp
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # The time the ticket will be snoozed until as a UTC Unix timestamp. If null, the ticket is not currently snoozed
    @jsondata:Name {value: "snoozed_until"}
    int snoozedUntil?;
    # Always ticket
    "ticket" 'type = "ticket";
    # The ID of the Ticket used in the Intercom Inbox and Messenger. Do not use ticket_id for API queries
    @jsondata:Name {value: "ticket_id"}
    string ticketId?;
    # The id representing the admin assigned to the ticket
    @jsondata:Name {value: "admin_assignee_id"}
    string adminAssigneeId?;
    # The id representing the team assigned to the ticket
    @jsondata:Name {value: "team_assignee_id"}
    string teamAssigneeId?;
    # The last time the ticket was updated as a UTC Unix timestamp
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # Whether or not the ticket is shared with the customer
    @jsondata:Name {value: "is_shared"}
    boolean isShared?;
    # The unique identifier for the ticket which is given by Intercom
    string id?;
    # Category of the Ticket
    "Customer"|"Back-office"|"Tracker" category?;
    # Custom attributes associated with the ticket
    @jsondata:Name {value: "ticket_attributes"}
    TicketCustomAttributes ticketAttributes?;
    # List of objects linked to the ticket
    @jsondata:Name {value: "linked_objects"}
    LinkedObjectList linkedObjects?;
    # The list of contacts affected by a ticket
    TicketContacts contacts?;
    # Whether or not the ticket is open. If false, the ticket is closed
    boolean open?;
};

# Represents a phone call in Intercom
public type Call record {
    # API URL to download or redirect to the call recording if available
    @jsondata:Name {value: "recording_url"}
    string? recordingUrl?;
    # Timestamp when the call was answered
    @jsondata:Name {value: "answered_at"}
    Datetime answeredAt?;
    # Timestamp when the call record was created
    @jsondata:Name {value: "created_at"}
    Datetime createdAt?;
    # String representing the object's type. Always has the value `call`
    string 'type?;
    # The id of the contact associated with the call, if any
    @jsondata:Name {value: "contact_id"}
    string? contactId?;
    # Timestamp when the call was initiated
    @jsondata:Name {value: "initiated_at"}
    Datetime initiatedAt?;
    # API URL to download or redirect to the call transcript if available
    @jsondata:Name {value: "transcription_url"}
    string? transcriptionUrl?;
    # Timestamp when the call record was last updated
    @jsondata:Name {value: "updated_at"}
    Datetime updatedAt?;
    # The phone number involved in the call, in E.164 format
    string? phone?;
    # API URL to the AI Agent (Fin) call transcript if available
    @jsondata:Name {value: "fin_transcription_url"}
    string? finTranscriptionUrl?;
    # The id of the conversation associated with the call, if any
    @jsondata:Name {value: "conversation_id"}
    string? conversationId?;
    # API URL to the AI Agent (Fin) call recording if available
    @jsondata:Name {value: "fin_recording_url"}
    string? finRecordingUrl?;
    # The id of the admin associated with the call, if any
    @jsondata:Name {value: "admin_id"}
    string? adminId?;
    # The id of the call
    string id?;
    # The current state of the call
    string state?;
    # The type of call
    @jsondata:Name {value: "call_type"}
    string callType?;
    # Timestamp when the call ended
    @jsondata:Name {value: "ended_at"}
    Datetime endedAt?;
    # The direction of the call
    string direction?;
    # The reason for the call end, if applicable
    @jsondata:Name {value: "ended_reason"}
    string? endedReason?;
};

# A Ticket Part represents a message in the ticket
public type TicketPart record {
    # The state of the ticket
    @jsondata:Name {value: "ticket_state"}
    "submitted"|"in_progress"|"waiting_on_customer"|"resolved" ticketState?;
    # The previous state of the ticket
    @jsondata:Name {value: "previous_ticket_state"}
    "submitted"|"in_progress"|"waiting_on_customer"|"resolved" previousTicketState?;
    # A list of attachments for the part
    PartAttachment[] attachments?;
    # Whether or not the ticket part has been redacted
    boolean redacted?;
    # The author that wrote or triggered the part. Can be a bot, admin, team or user
    TicketPartAuthor author?;
    # The app package code if this part was created via API. Note this field won't show if the part was not created via API
    @jsondata:Name {value: "app_package_code"}
    string appPackageCode?;
    # The time the ticket part was created
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # The type of ticket part
    @jsondata:Name {value: "part_type"}
    string partType?;
    # The external id of the ticket part
    @jsondata:Name {value: "external_id"}
    string? externalId?;
    # Always ticket_part
    string 'type?;
    # The message body, which may contain HTML
    string? body?;
    # The last time the ticket part was updated
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # Data for attributes that were updated in this ticket part
    @jsondata:Name {value: "updated_attribute_data"}
    UpdatedAttribute? updatedAttributeData?;
    # The id representing the ticket part
    string id?;
    # Reference to the teammate or team assigned to handle the ticket
    @jsondata:Name {value: "assigned_to"}
    Reference assignedTo?;
};

