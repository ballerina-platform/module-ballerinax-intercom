# A Conversation Part represents a message in the conversation
public type ConversationPart record {
    # Metadata for a conversation part
    ConversationPartMetadata metadata?;
    # A list of attachments for the part
    PartAttachment[] attachments?;
    # Whether or not the conversation part has been redacted
    boolean redacted?;
    # The object who initiated the conversation, which can be a Contact, Admin or Team. Bots and campaigns send messages on behalf of Admins or Teams. For Twitter, this will be blank
    ConversationPartAuthor author?;
    # The app package code if this part was created via API. null if the part was not created via API
    @jsondata:Name {value: "app_package_code"}
    string? appPackageCode?;
    # The time the conversation part was created
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # The type of conversation part
    @jsondata:Name {value: "part_type"}
    string partType?;
    # The external id of the conversation part
    @jsondata:Name {value: "external_id"}
    string? externalId?;
    # Always conversation_part
    string 'type?;
    # The message body, which may contain HTML. For Twitter, this will show a generic message regarding why the body is obscured. In webhook payloads for API version 2.15+, this field returns plain text
    string? body?;
    # A list of tags objects associated with the conversation part
    TagBasic[]? tags?;
    # The last time the conversation part was updated
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # Detailed information about events associated with the conversation part
    @jsondata:Name {value: "event_details"}
    EventDetails eventDetails?;
    # The id representing the conversation part
    string id?;
    # The time the user was notified with the conversation part
    @jsondata:Name {value: "notified_at"}
    int notifiedAt?;
    # Indicates the current state of conversation when the conversation part was created
    "open"|"closed"|"snoozed" state?;
    # Metadata specific to email messages in the conversation part
    @jsondata:Name {value: "email_message_metadata"}
    EmailMessageMetadata emailMessageMetadata?;
    # The user or team assigned to handle the conversation part
    @jsondata:Name {value: "assigned_to"}
    Reference assignedTo?;
};

# The request payload for creating a ticket type.
#   You can copy the `icon` property for your ticket type from [Twemoji Cheatsheet](https://twemoji-cheatsheet.vercel.app/)
public type CreateTicketTypeRequest record {
