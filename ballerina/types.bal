    int updatedAt?;
    # Custom attributes defined for this ticket type
    @jsondata:Name {value: "ticket_type_attributes"}
    TicketTypeAttributeList ticketTypeAttributes?;
    # The name of the ticket type
    string name?;
    # The icon of the ticket type
    string icon?;
    # The description of the ticket type
    string description?;
    # The date and time the ticket type was created
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # The id representing the ticket type
    string id?;
    # String representing the object's type. Always has the value `ticket_type`
    string 'type?;
    # Category of the Ticket Type
    "Customer"|"Back-office"|"Tracker" category?;
};

# Additional data provided about Admin activity
public type ActivityLogMetadata record {
    # The team assignment limit value (null if limit was removed)
    @jsondata:Name {value: "team_assignment_limit"}
    int? teamAssignmentLimit?;
    # The name of the Admin who initiated the activity
    @jsondata:Name {value: "update_by_name"}
    string? updateByName?;
    # The state of settings or values before the change. Structure varies by activity type
    record {}? before?;
    # Indicates if the status was changed automatically or manually
    @jsondata:Name {value: "auto_changed"}
    string? autoChanged?;
    # Indicates if conversations should be reassigned while an Admin is away
    @jsondata:Name {value: "reassign_conversations"}
    boolean? reassignConversations?;
    # The unique identifier for the contact which is provided by the Client
    @jsondata:Name {value: "external_id"}
    string? externalId?;
    # The away mode status which is set to true when away and false when returned
    @jsondata:Name {value: "away_mode"}
    boolean? awayMode?;
    # The action that initiated the status change
    string? 'source?;
    # Details about the team whose assignment limit was changed
    ActivityLogMetadataTeam? team?;
    # The timestamp when the impersonation consent expires
    @jsondata:Name {value: "expired_at"}
    string? expiredAt?;
    # Indicates if the setting is enabled or disabled
    boolean? enabled?;
    # The mode of the setting (e.g., when_away_only, when_away_and_reassign)
    string? mode?;
    # The reason the Admin is away
    @jsondata:Name {value: "away_status_reason"}
    string? awayStatusReason?;
    # The conversation assignment limit value for an admin
    @jsondata:Name {value: "conversation_assignment_limit"}
    int? conversationAssignmentLimit?;
    # The ticket assignment limit value for an admin
    @jsondata:Name {value: "ticket_assignment_limit"}
    int? ticketAssignmentLimit?;
    # The state of settings or values after the change. Structure varies by activity type
    record {}? after?;
    # The ID of the Admin who initiated the activity
    @jsondata:Name {value: "update_by"}
    int? updateBy?;
    # The way the admin signed in
    @jsondata:Name {value: "sign_in_method"}
    string? signInMethod?;
    # The ID of the impersonation consent
    @jsondata:Name {value: "consent_id"}
    int? consentId?;
};

# You can Update an Article
public type UpdateArticleRequest record {
    # Translated content versions for the article update
    @jsondata:Name {value: "translated_content"}
    ArticleTranslatedContent? translatedContent?;
    # The id of the article's parent collection or section. An article without this field stands alone
    @jsondata:Name {value: "parent_id"}
    string parentId?;
    # The description of the article. For multilingual articles, this will be the description of the default language's content
    string description?;
    # Whether the article will be `published` or will be a `draft`. Defaults to draft. For multilingual articles, this will be the state of the default language's content
    "published"|"draft" state?;
    # The title of the article.For multilingual articles, this will be the title of the default language's content
    string title?;
    # The content of the article. For multilingual articles, this will be the body of the default language's content
    string body?;
    # The id of the author of the article. For multilingual articles, this will be the id of the author of the default language's content. Must be a teammate on the help center's workspace
    @jsondata:Name {value: "author_id"}
    int authorId?;
    # The type of parent, which can either be a `collection` or `section`
    @jsondata:Name {value: "parent_type"}
    string parentType?;
};

