# Base request object for creating contact replies with attachments and options
public type ContactReplyBaseRequest record {
    # A list of image URLs that will be added as attachments. You can include up to 10 URLs
    @jsondata:Name {value: "attachment_urls"}
    string[] attachmentUrls?;
    # The time the reply was created. If not provided, the current time will be used
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # The type of message being sent (always 'comment')
    @jsondata:Name {value: "message_type"}
    "comment" messageType;
    # The sender type for the reply (always 'user')
    "user" 'type;
    # The text body of the comment
    string body;
    # The quick reply selection the contact wishes to respond with. These map to buttons displayed in the Messenger UI if sent by a bot, or the reply options sent by an Admin via the API
    @jsondata:Name {value: "reply_options"}
    QuickReplyOption1[] replyOptions?;
};

