};

# A Ticket Part representing a note, comment, or quick_reply on a ticket
public type TicketReply record {
    # A list of attachments for the part
    PartAttachment[] attachments?;
    # The last time the note was updated
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # Whether or not the ticket part has been redacted
    boolean redacted?;
    # The author that wrote or triggered the part. Can be a bot, admin, team or user
    TicketPartAuthor author?;
    # The time the note was created
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # Type of the part
    @jsondata:Name {value: "part_type"}
    string partType?;
    # The id representing the part
    string id?;
    # Always ticket_part
    "ticket_part" 'type?;
    # The message body, which may contain HTML
    string? body?;
};

# An object containing social profiles that a contact has
public type ContactSocialProfiles record {
