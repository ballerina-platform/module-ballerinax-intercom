# A Statistics object containing all information required for reporting, with timestamps and calculated metrics
public type ConversationStatistics record {
    # Duration until first admin reply. Subtracts out of business hours. In seconds
    @jsondata:Name {value: "time_to_admin_reply"}
    int timeToAdminReply?;
    # Time of the last conversation part from a contact
    @jsondata:Name {value: "last_contact_reply_at"}
    int lastContactReplyAt?;
    # Time of the last conversation close
    @jsondata:Name {value: "last_close_at"}
    int lastCloseAt?;
    # Number of assignments after first_contact_reply_at
    @jsondata:Name {value: "count_assignments"}
    int countAssignments?;
    # Total number of conversation parts
    @jsondata:Name {value: "count_conversation_parts"}
    int countConversationParts?;
    # Time of first close after first_contact_reply_at
    @jsondata:Name {value: "first_close_at"}
    int firstCloseAt?;
    # Duration until conversation was closed last time. Subtracts out of business hours. In seconds
    @jsondata:Name {value: "time_to_last_close"}
    int timeToLastClose?;
    string 'type?;
    # Time of first assignment after first_contact_reply_at
    @jsondata:Name {value: "first_assignment_at"}
    int firstAssignmentAt?;
    # Number of reopens after first_contact_reply_at
    @jsondata:Name {value: "count_reopens"}
    int countReopens?;
    # Duration until last assignment before first admin reply. In seconds
    @jsondata:Name {value: "time_to_assignment"}
    int timeToAssignment?;
    # Median based on all admin replies after a contact reply. Subtracts out of business hours. In seconds
    @jsondata:Name {value: "median_time_to_reply"}
    int medianTimeToReply?;
    # Time of first admin reply after first_contact_reply_at
    @jsondata:Name {value: "first_admin_reply_at"}
    int firstAdminReplyAt?;
    # An array of conversation response time objects
    @jsondata:Name {value: "assigned_team_first_response_time_by_team"}
    ConversationResponseTime[] assignedTeamFirstResponseTimeByTeam?;
    # Adjusted handling time for conversation in seconds. This is the active handling time excluding idle periods when teammates are not actively working on the conversation
    @jsondata:Name {value: "adjusted_handling_time"}
    int? adjustedHandlingTime?;
    # Duration until conversation was closed first time. Subtracts out of business hours. In seconds
    @jsondata:Name {value: "time_to_first_close"}
    int timeToFirstClose?;
    # An array of conversation response time objects within office hours
    @jsondata:Name {value: "assigned_team_first_response_time_in_office_hours"}
    ConversationResponseTime[] assignedTeamFirstResponseTimeInOfficeHours?;
    # Time of first admin reply since most recent assignment
    @jsondata:Name {value: "last_assignment_admin_reply_at"}
    int lastAssignmentAdminReplyAt?;
    # Time of last assignment after first_contact_reply_at
    @jsondata:Name {value: "last_assignment_at"}
    int lastAssignmentAt?;
    # Time of first text conversation part from a contact
    @jsondata:Name {value: "first_contact_reply_at"}
    int firstContactReplyAt?;
    # The last admin who closed the conversation. Returns a reference to an Admin object
    @jsondata:Name {value: "last_closed_by_id"}
    string lastClosedById?;
    # Time from conversation assignment to conversation close in seconds
    @jsondata:Name {value: "handling_time"}
    int handlingTime?;
    # Time of the last conversation part from an admin
    @jsondata:Name {value: "last_admin_reply_at"}
    int lastAdminReplyAt?;
};

