# Companies allow you to represent organizations using your product. Each company will have its own description and be associated with contacts. You can fetch, create, update and list companies
public type Company record {
    # The URL for the company website
    string website?;
    # The company id you have defined for the company
    @jsondata:Name {value: "company_id"}
    string companyId?;
    # The time the company last recorded making a request
    @jsondata:Name {value: "last_request_at"}
    int lastRequestAt?;
    # The time the company was added in Intercom
    @jsondata:Name {value: "created_at"}
    int createdAt?;
    # The industry that the company operates in
    string industry?;
    # Value is `company`
    "company" 'type?;
    # The custom attributes you have set on the company
    @jsondata:Name {value: "custom_attributes"}
    record {|string...;|} customAttributes?;
    # The list of tags associated with the company
    CompanyTags tags?;
    # The list of segments associated with the company
    CompanySegments segments?;
    # How much revenue the company generates for your business
    @jsondata:Name {value: "monthly_spend"}
    int monthlySpend?;
    # The last time the company was updated
    @jsondata:Name {value: "updated_at"}
    int updatedAt?;
    # The number of employees in the company
    int size?;
    # The number of users in the company
    @jsondata:Name {value: "user_count"}
    int userCount?;
    # How many sessions the company has recorded
    @jsondata:Name {value: "session_count"}
    int sessionCount?;
    # The name of the company
    string name?;
    # The Intercom defined id representing the company
    string id?;
    # The time the company was created by you
    @jsondata:Name {value: "remote_created_at"}
    int remoteCreatedAt?;
    # The Intercom defined code of the workspace the company is associated to
    @jsondata:Name {value: "app_id"}
    string appId?;
    # Company subscription plan details
    CompanyPlan plan?;
};

# This will return a list of companies for the App
public type CompanyList record {
    # Cursor-based pagination is a technique used in the Intercom API to navigate through large amounts of data.
    # A "cursor" or pointer is used to keep track of the current position in the result set, allowing the API to return the data in small chunks or "pages" as needed
    CursorPages? pages?;
    # An array containing Company Objects
    Company[] data?;
    # The total number of companies
    @jsondata:Name {value: "total_count"}
    int totalCount?;
    # The type of object - `list`
    "list" 'type?;
};

